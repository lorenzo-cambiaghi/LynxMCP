{
  "config_version": 2,
  "storage_path": "./rag_storage",
  "loading_timeout_seconds": 600,
  "embedding": {
    "model_name": "BAAI/bge-small-en-v1.5"
  },
  "search": {
    "default_top_k": 8,
    "mode": "hybrid",
    "rrf_k": 60,
    "candidate_pool_size": 30,
    "deep": {
      "min_results": 2,
      "score_thresholds": {
        "dense": 0.45,
        "hybrid": 0.012,
        "sparse": 3.0
      }
    }
  },
  "sources": {
    "myproject": {
      "type": "codebase",
      "path": "C:/path/to/your/codebase",
      "supported_extensions": [
        ".py",
        ".js",
        ".ts",
        ".tsx",
        ".jsx",
        ".java",
        ".cs",
        ".cpp",
        ".c",
        ".h",
        ".hpp",
        ".go",
        ".rs",
        ".rb",
        ".php",
        ".md",
        ".txt",
        ".json",
        ".yaml",
        ".yml"
      ],
      "ignored_path_fragments": [
        "/.git/",
        "/node_modules/",
        "/dist/",
        "/build/",
        "/target/",
        "/.venv/",
        "/__pycache__/",
        "/.idea/",
        "/.vscode/"
      ],
      "watcher": {
        "enabled": true,
        "debounce_seconds": 2.0
      },
      "git_integration": {
        "enabled": true
      }
    },
    "exampleDocs_remove_or_replace": {
      "_comment": "Webdoc example — uncomment and adapt the URL to crawl a public docs site. Run `lynx build --source <name>` to fetch + index, again whenever you want a refresh (never automatic).",
      "type": "webdoc",
      "url": "https://example.com/docs/",
      "max_depth": 3,
      "max_pages": 500,
      "same_origin_only": true,
      "include_url_patterns": ["/docs/"],
      "exclude_url_patterns": ["/docs/legacy/"],
      "request_delay_seconds": 0.5
    }
  }
}
