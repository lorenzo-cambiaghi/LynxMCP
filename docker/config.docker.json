{
  "config_version": 2,
  "storage_path": "/data/rag_storage",
  "embedding": {
    "model_name": "BAAI/bge-small-en-v1.5"
  },
  "search": {
    "default_top_k": 8,
    "mode": "hybrid"
  },
  "sources": {
    "workspace": {
      "type": "codebase",
      "path": "/workspace",
      "supported_extensions": [
        ".py", ".js", ".ts", ".tsx", ".jsx", ".java", ".cs",
        ".cpp", ".c", ".h", ".hpp", ".go", ".rs", ".rb", ".php",
        ".kt", ".swift", ".sh", ".bash", ".sql", ".scala", ".sc", ".lua",
        ".md", ".txt", ".json", ".yaml", ".yml"
      ],
      "ignored_path_fragments": [
        "/.git/", "/node_modules/", "/dist/", "/build/",
        "/target/", "/.venv/", "/__pycache__/", "/.idea/", "/.vscode/"
      ],
      "watcher": {
        "enabled": true,
        "debounce_seconds": 2.0
      },
      "git_integration": {
        "enabled": false
      },
      "graph": {
        "enabled": true
      }
    }
  }
}
